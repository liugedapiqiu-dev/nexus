{
  "_comment": "用户身份映射配置 - 将所有标识符映射到主会话",
  "_updated": "2026-04-02",
  "_desc": "解决 OpenClaw 按渠道创建会话导致的重复问题",

  "primary_user": {
    "name": "[YOUR_NAME]",
    "primary_chat_id": "[YOUR_PRIMARY_CHAT_ID]",
    "aliases": {
      "user_id": "[YOUR_USER_ID]",
      "open_id": "[YOUR_OPEN_ID]",
      "union_id": "[YOUR_UNION_ID]"
    }
  },

  "routing_rules": [
    {
      "rule": "feishu_direct_message",
      "match": {
        "channel": "feishu",
        "type": "p2p"
      },
      "action": "route_to_primary",
      "target_session": "feishu:default:[YOUR_PRIMARY_CHAT_ID]"
    },
    {
      "rule": "feishu_user_alias",
      "match_any_user_id": ["[YOUR_USER_ID]", "[YOUR_OPEN_ID]"],
      "action": "merge_to_primary",
      "target_session": "feishu:default:[YOUR_PRIMARY_CHAT_ID]"
    }
  ],

  "cleanup_policy": {
    "auto_merge": true,
    "auto_delete_duplicates": true,
    "preserve_session": "feishu:default:[YOUR_PRIMARY_CHAT_ID]"
  }
}
