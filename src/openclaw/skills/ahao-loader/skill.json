{
  "name": "ahao-loader",
  "version": "1.0.0",
  "description": "[YOUR_AI_NAME]后台加载器 - 独立进程加载记忆和状态，不依赖会话生命周期",
  "author": "[YOUR_AI_NAME] 🧠",
  "entry": "python_script",
  "script": "background_loader.py",
  "trigger": {
    "intents": [
      "加载记忆",
      "初始化状态",
      "后台加载",
      "会话准备",
      "记忆预加载"
    ],
    "keywords": [
      "加载记忆",
      "后台加载",
      "状态初始化",
      "预加载",
      "会话启动"
    ]
  },
  "capabilities": {
    "memory_loading": "从 VectorBrain 加载情景记忆和知识记忆",
    "task_loading": "加载待办任务队列",
    "status_tracking": "更新加载状态到 .ahao_loading_status.json",
    "independent_process": "独立进程运行，不依赖会话生命周期",
    "pid_management": "PID 文件管理，防止重复启动",
    "heartbeat_monitoring": "心跳监测确保加载器正常运行"
  },
  "config": {
    "status_file": "~/.openclaw/workspace/.ahao_loading_status.json",
    "pid_file": "/tmp/ahao_loader.pid",
    "vectorbrain_home": "~/.vectorbrain/",
    "databases": {
      "episodic_memory": "~/.vectorbrain/memory/episodic_memory.db",
      "knowledge_memory": "~/.vectorbrain/memory/knowledge_memory.db",
      "reflections": "~/.vectorbrain/reflection/reflections.db",
      "tasks": "~/.vectorbrain/tasks/task_queue.db",
      "goals": "~/.vectorbrain/goals/goals.db"
    },
    "timezone": "Asia/Shanghai (UTC+8)"
  },
  "output": {
    "format": "json",
    "status_file": ".ahao_loading_status.json",
    "fields": [
      "session_id",
      "start_time",
      "status",
      "progress",
      "message",
      "last_heartbeat"
    ]
  },
  "loading_levels": {
    "level_1": "核心身份加载 (SOUL.md, IDENTITY.md)",
    "level_2": "工作上下文检索 (USER.md, TOOLS.md, AGENTS.md)",
    "level_3": "记忆系统初始化 (VectorBrain 连接)",
    "level_4": "待办事项加载 (任务队列)",
    "level_5": "系统检测 (后台运行)"
  },
  "bug_protections": [
    "PID 文件清理 - 防止进程泄露",
    "原子写入 - 状态文件损坏防护",
    "容错机制 - 单级失败不影响整体",
    "时区统一 - Asia/Shanghai (标准库)"
  ]
}
