{
  "schema_version": "0.1.0-draft",
  "registry_id": "desktop-control",
  "canonical_name": "desktop-control",
  "scope": "RGA safety baseline for high-risk desktop tasks, especially message sending",
  "source_documents": [
    "skills/desktop-control/RGA_MESSAGE_SAFETY_SPEC.md",
    "skills/skills.registry.json",
    "/home/user/.openclaw/skills/desktop-control/SKILL.md",
    "/home/user/.openclaw/skills/desktop-control/skill.json"
  ],
  "task_kinds": [
    "desktop.message.send",
    "desktop.message.reply",
    "desktop.message.forward",
    "desktop.form.submit"
  ],
  "risk_model": {
    "L0": "observe-only",
    "L1": "navigation-only",
    "L2": "draft/write-prep",
    "L3": "externally effective irreversible-or-costly action"
  },
  "required_states": [
    "INIT",
    "ACTIVATE_APP",
    "VERIFY_APP_READY",
    "LOCATE_TARGET",
    "VERIFY_TARGET",
    "FOCUS_COMPOSER",
    "COMPOSE_DRAFT",
    "VERIFY_DRAFT",
    "PRE_SEND_CONFIRM",
    "SEND_ACTION",
    "VERIFY_SENT",
    "DONE"
  ],
  "required_gates": {
    "gate_a_target_verification": {
      "required": true,
      "abort_on_failure": true,
      "minimum_evidence": [
        "window_or_header_match",
        "sidebar_or_selected_item_match",
        "ocr_or_structured_label_match"
      ]
    },
    "gate_b_draft_verification": {
      "required": true,
      "abort_on_failure": true,
      "minimum_evidence": [
        "ocr_readback_or_clipboard_readback",
        "normalized_text_match"
      ]
    },
    "gate_c_send_confirmation": {
      "required": true,
      "abort_on_failure": true,
      "minimum_evidence": [
        "policy_allow_or_human_confirm"
      ]
    },
    "gate_d_sent_verification": {
      "required": true,
      "abort_on_failure": false,
      "escalate_on_failure": true,
      "minimum_evidence": [
        "message_history_new_item_or_sent_indicator"
      ]
    }
  },
  "failure_policy": {
    "retryable": [
      "app_not_active",
      "search_not_ready",
      "composer_not_focused",
      "temporary_ocr_failure",
      "ui_refresh_delay"
    ],
    "abort_immediately": [
      "target_mismatch",
      "target_ambiguous",
      "draft_unverified",
      "missing_send_confirmation",
      "destructive_dialog_detected"
    ],
    "never_auto_retry_send": true,
    "unknown_send_state_requires_human_review": true
  },
  "current_capability_mapping": {
    "activate_window": ["ACTIVATE_APP", "VERIFY_APP_READY"],
    "mouse_click": ["LOCATE_TARGET", "FOCUS_COMPOSER", "SEND_ACTION"],
    "mouse_move": ["LOCATE_TARGET", "SEND_ACTION"],
    "keyboard_type": ["LOCATE_TARGET", "COMPOSE_DRAFT"],
    "keyboard_press": ["LOCATE_TARGET", "SEND_ACTION"],
    "screenshot": ["VERIFY_APP_READY", "VERIFY_TARGET", "VERIFY_DRAFT", "VERIFY_SENT"],
    "image_search": ["LOCATE_TARGET", "FOCUS_COMPOSER", "SEND_ACTION"]
  },
  "known_gaps": [
    "No standardized OCR/text-readback interface in desktop-control contract",
    "No machine-readable verification result structure with confidence/evidence",
    "No mandatory gate policy for high-risk actions in current skill docs",
    "No explicit distinction between action executed and effect verified",
    "No task-level audit/event schema for state-machine execution",
    "No per-platform send semantics config (Enter vs newline vs button)"
  ],
  "checks": {
    "L1": [
      "Task definition includes required_states",
      "Task policy includes require_target_verification/require_draft_verification/require_send_confirmation/require_sent_verification",
      "Executor can emit step status and evidence structure"
    ],
    "L2": [
      "Can activate target messaging app",
      "Can locate conversation without sending",
      "Can verify target before composing",
      "Can compose draft and verify it",
      "Stops at PRE_SEND_CONFIRM when approval missing",
      "Returns unknown or needs-human-review if sent state cannot be verified"
    ],
    "L3": [
      "High-risk tasks cannot bypass Gate A/B/C/D",
      "Target mismatch aborts instead of guessing",
      "Unverified draft cannot be sent",
      "Unknown sent state does not trigger automatic second send",
      "Success means effect verified, not just click/keypress executed"
    ]
  },
  "sample_task": {
    "kind": "desktop.message.send",
    "version": "0.1",
    "risk_level": "L3",
    "app": {
      "name": "feishu",
      "window_hint": "飞书"
    },
    "target": {
      "name": "[YOUR_NAME]",
      "type": "person",
      "disambiguation_hint": "供应链主管"
    },
    "message": {
      "text": "测试消息：RGA 规范验证",
      "compare_mode": "normalized"
    },
    "policy": {
      "require_target_verification": true,
      "require_draft_verification": true,
      "require_send_confirmation": true,
      "require_sent_verification": true,
      "max_retries_per_step": 1,
      "allow_send_via_enter": false
    },
    "verification": {
      "target_sources": ["header", "sidebar", "ocr"],
      "draft_sources": ["ocr", "clipboard-readback"],
      "sent_sources": ["message-list", "composer-empty"]
    },
    "artifacts": {
      "save_screenshots": true,
      "save_ocr_text": true
    }
  }
}
